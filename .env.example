# Database — Railway PostgreSQL plugin sets this automatically.
# For local dev: use your own PostgreSQL connection string.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Auth — generate a strong random secret (e.g. openssl rand -hex 32)
AUTH_SECRET="replace-with-a-long-random-secret"

# Cloudinary — create a free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
