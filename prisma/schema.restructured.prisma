// ============================================================================
// RESTRUCTURED SCHEMA — TARGET DESIGN (NOT YET ACTIVE)
// ----------------------------------------------------------------------------
// This is the proposed clean restructuring of the backend, preserving the same
// domain while introducing:
//   - Postgres enums for fixed value sets (type, category, gender, status, role…)
//   - jsonb (Prisma `Json`) for array/object fields currently stored as String
//   - tightened constraints + a couple of helpful indexes
//
// It is intentionally a SEPARATE file so the live `schema.prisma` keeps building.
// Apply only after: (1) a test DB validates the data-preserving migration in
// BACKEND_REWRITE.md, and (2) the code layer (serialize.ts, types, write-path
// routes, seed) is updated in lockstep. See BACKEND_REWRITE.md for the plan.
// ============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------- Enums ----------------------------------------

enum SchoolType {
  daycare
  kindergarten
  primary
  secondary
  secondary_o
  secondary_oa
  tertiary
  university
}

enum SchoolCategory {
  day
  boarding
  mixed
}

enum SchoolGender {
  mixed
  girls_only
  boys_only
}

enum SchoolStatus {
  pending
  active
  rejected
  suspended
}

enum UserRole {
  user
  school
  admin
}

enum LeadStatus {
  new
  contacted
  enrolled
  closed
}

enum ConversationStatus {
  open
  closed
}

enum PaymentStatus {
  paid
  pending
  failed
  refunded
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  expired
}

enum TicketStatus {
  open
  pending
  resolved
  closed
}

enum TicketPriority {
  low
  normal
  high
  urgent
}

// ----------------------------- Models ---------------------------------------

model School {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  ownerUserId      String?
  owner            User?          @relation("SchoolOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  type             SchoolType
  category         SchoolCategory
  gender           SchoolGender   @default(mixed)
  description      String
  shortDescription String
  logo             String         @default("")
  coverImage       String         @default("")
  gallery          Json           @default("[]")
  videos           Json           @default("[]")
  address          String
  city             String
  region           String
  country          String         @default("Uganda")
  latitude         Float          @default(0)
  longitude        Float          @default(0)
  phone            String
  email            String
  website          String?
  whatsapp         String?
  currency         String         @default("UGX")
  dayMin           Int
  dayMax           Int
  boardingMin      Int?
  boardingMax      Int?
  facilities       Json           @default("[]")
  rating           Float          @default(0)
  reviewCount      Int            @default(0)
  isVerified       Boolean        @default(false)
  isFeatured       Boolean        @default(false)
  isPremium        Boolean        @default(false)
  status           SchoolStatus   @default(pending)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  reviews          Review[]
  leads            Lead[]
  payments         Payment[]
  subscription     SchoolSubscription?
  conversations    Conversation[]

  @@index([status, isFeatured])
  @@index([type, status])
  @@index([city])
}

model Review {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId     String
  userName   String
  userAvatar String?
  rating     Int
  title      String
  content    String
  createdAt  DateTime @default(now())

  @@index([schoolId, createdAt])
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          UserRole       @default(user)
  avatar        String?
  favorites     Json           @default("[]")
  createdAt     DateTime       @default(now())
  notifications Notification[]
  schools       School[]       @relation("SchoolOwner")
  conversations Conversation[] @relation("ConversationUser")
  messages      Message[]
}

model Conversation {
  id            String             @id @default(cuid())
  schoolId      String
  school        School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId        String
  user          User               @relation("ConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  subject       String
  status        ConversationStatus @default(open)
  lastMessageAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  messages      Message[]

  @@index([schoolId, lastMessageAt])
  @@index([userId, lastMessageAt])
  @@index([status])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderRole     UserRole
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model SubscriptionPlan {
  id            String               @id
  name          String
  price         Int
  currency      String               @default("UGX")
  period        String
  features      Json                 @default("[]")
  isFeatured    Boolean              @default(false)
  isActive      Boolean              @default(true)
  sortOrder     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  subscriptions SchoolSubscription[]
}

model SchoolSubscription {
  id          String             @id @default(cuid())
  schoolId    String             @unique
  planId      String
  status      SubscriptionStatus @default(active)
  periodStart DateTime           @default(now())
  periodEnd   DateTime?
  autoRenew   Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments    Payment[]
}

model Lead {
  id        String     @id @default(cuid())
  schoolId  String
  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  message   String
  status    LeadStatus @default(new)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([schoolId, status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorName  String
  action     String
  resource   String
  resourceId String?
  details    Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([resource])
}

model SupportTicket {
  id             String         @id @default(cuid())
  submitterName  String
  submitterEmail String
  subject        String
  message        String
  status         TicketStatus   @default(open)
  priority       TicketPriority @default(normal)
  adminNote      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status, priority])
}

model CmsSection {
  id        String   @id
  title     String
  content   Json     @default("{}")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id             String              @id @default(cuid())
  schoolId       String
  school         School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   SchoolSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  amount         Int
  currency       String              @default("UGX")
  status         PaymentStatus       @default(paid)
  method         String?
  reference      String?
  paidAt         DateTime            @default(now())
  createdAt      DateTime            @default(now())

  @@index([schoolId, status])
  @@index([subscriptionId])
}
